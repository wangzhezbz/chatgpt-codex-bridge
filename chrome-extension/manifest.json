{
  "manifest_version": 3,
  "name": "Codex GPT Bridge",
  "version": "0.1.0",
  "description": "Sync Codex workbench messages with a bound GPT session.",
  "permissions": [
    "downloads",
    "debugger",
    "scripting",
    "tabs"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "https://chatgpt.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://chatgpt.com/*"],
      "js": ["bridge-config.js", "content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
